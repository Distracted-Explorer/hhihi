# App
APP_NAME=VQA Backend
APP_ENV=development
API_KEY=change-me-supersecret

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# OCR
OCR_LANGUAGES=en
OCR_GPU=false
TEMP_IMAGE_DIR=./data/uploads

# LLM provider: ollama | gemini | openai
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-flash
LLM_TEMPERATURE=0.2

# Provider keys
OPENAI_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Cache / Duplicates
CACHE_SIZE=128
SIMILARITY_THRESHOLD=0.92

# Rate limiting
RATE_LIMIT=30/minute

# Logging
LOG_LEVEL=INFO